FROM golang:1.24-alpine AS build
WORKDIR /src

COPY go.mod go.sum ./
RUN go mod download

COPY . .

ARG VERSION=dev
ARG COMMIT=none
ARG BUILD_DATE=unknown
ARG TARGETOS
ARG TARGETARCH

RUN CGO_ENABLED=0 GOOS=${TARGETOS} GOARCH=${TARGETARCH} go build \
    -ldflags "-s -w \
      -X github.com/blink-zero/esxport/internal/version.Version=${VERSION} \
      -X github.com/blink-zero/esxport/internal/version.Commit=${COMMIT} \
      -X github.com/blink-zero/esxport/internal/version.BuildDate=${BUILD_DATE}" \
    -o /out/esxport ./cmd/esxport

FROM alpine:3.21
RUN apk add --no-cache ca-certificates
COPY --from=build /out/esxport /usr/local/bin/esxport

EXPOSE 9272

ENTRYPOINT ["esxport"]
CMD ["serve"]
